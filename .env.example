# Integration repository local validation example.
# Copy to a local, untracked .env only if you need these shortcuts.
# Do not commit real tokens, private keys, database passwords, or API secrets.

# Optional label consumed by adapter tests and local scripts.
# This is not a production profile selector.
HERMES_PROFILE=local-test

# Hermes profile command or alias used by scripts/check_hermes_profile_plugin.py.
# Example: a wrapper created by `hermes profile alias`.
HERMES_PROFILE_CMD=REPLACE_WITH_LOCAL_HERMES_PROFILE_COMMAND

# Optional explicit Python interpreter for the Hermes runtime.
# If unset, scripts/check_hermes_profile_plugin.py tries to infer it from `hermes`.
HERMES_RUNTIME_PYTHON=REPLACE_WITH_HERMES_RUNTIME_PYTHON

# Executor service base URL used by hermes-polymarket-executor-adapter.
PM_EXEC_SERVICE_URL=http://localhost:8080

# Bearer token for executor service/query routes.
# Must match PM_EXEC_SERVICE_TOKEN in the executor API process.
PM_EXEC_SERVICE_TOKEN=REPLACE_WITH_SERVICE_BEARER_TOKEN

# Optional bearer token for executor admin routes.
# Must be distinct from PM_EXEC_SERVICE_TOKEN.
PM_EXEC_ADMIN_TOKEN=REPLACE_WITH_DISTINCT_ADMIN_BEARER_TOKEN
